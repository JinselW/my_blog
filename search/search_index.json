{"config":{"lang":["zh"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u6b22\u8fce\u56de\u5230\u5c0f\u7a9d\u7a9d~","text":"<p>\u6700\u540e\u66f4\u65b0\u4e8e {{ page.meta.git_revision_date_localized }}</p> <p>\u4eba\u751f\u662f\u4e00\u573a\u4f53\u9a8c\uff0c\u6210\u957f\u4e5f\u603b\u5728\u4e0d\u7ecf\u610f\u95f4\u8fdb\u884c\u3002</p> <p>\u6240\u4ee5\u6211\u4eec\u9009\u62e9\u8bb0\u5f55\uff0c\u7559\u4e0b\u6211\u4eec\u884c\u8d70\u7684\u8db3\u8ff9~</p> <p>\u8bf7\u5728\u8fd9\u91cc\uff0c\u7545\u6240\u6b32\u8a00\uff0c\u8bc9\u8bf4\u4f60\u5f53\u4e0b\u7684\u60f3\u6cd5\uff0c\u7559\u7ed9\u672a\u6765\u7684\u6211\u4eec\u56de\u671b......</p>"},{"location":"tags/","title":"\u6807\u7b7e","text":"<p>{% include \"tags.html\" %}</p>"},{"location":"%E8%AE%B8%E4%B8%89%E8%A7%82%E5%8D%96%E8%A1%80%E8%AE%B0/","title":"\u8bb8\u4e09\u89c2\u5356\u8840\u8bb0","text":"<p>{{ page.meta.date }}</p> <p>\u4e0d\u6127\u662f\u4f59\u534e\u7684\u6587\uff0c\u5e73\u9759\u7684\u53d9\u8ff0\u7740\u6240\u6709\u7684\u82e6\u96be\u3002\u4ed6\u4e0d\u8bc4\u8bba\uff0c\u4f3c\u4e4e\u53ea\u662f\u4e00\u4e2a\u8bb0\u5f55\u8005\uff0c\u8046\u542c\u7740\u6bcf\u4e00\u4e2a\u89d2\u8272\u7684\u81ea\u6211\u53d9\u8ff0\u3002</p> <p>\u56de\u987e\u4e0b\u8bb8\u4e09\u89c2\u7684\u5356\u8840\u7ecf\u5386</p> <ul> <li>\u7b2c\u4e00\u6b21\uff0c\u5a36\u4e86\u5f90\u7389\u5170\u3002\u8ddf\u7740\u963f\u65b9\u548c\u6839\u9f99\uff0c\u7b2c\u4e00\u6b21\u5b8c\u6574\u5730\u201c\u4f53\u9a8c\u201d\u4e86\u5356\u8840\u3002\u77e5\u9053\u5356\u8840\u524d\u8981\u559d\u597d\u591a\u597d\u591a\u6c34\uff0c\u77e5\u9053\u5356\u5b8c\u8840\u8981\u5230\u996d\u5e97\u53bb\u70b9\u4e00\u76d8\u7092\u732a\u809d\uff08\u751f\u8840\uff09\u548c\u4e8c\u4e24\u9ec4\u9152\uff08\u6d3b\u8840\uff09\u3002</li> <li>\u7b2c\u4e8c\u6b21\uff0c\u66ff\u4e00\u4e50\u8d54\u94b1\u3002\u8fd9\u4e00\u6b21\u4e00\u4e50\u4e3a\u4e86\u7ed9\u4e8c\u4e50\u3001\u4e09\u4e50\u6491\u53e3\u6c14\uff0c\u628a\u65b9\u94c1\u5320\u7684\u5927\u513f\u5b50\u5934\u7838\u7834\u4e86\u3002\u4e00\u4e50\u7684\u8eab\u4e16\u7b97\u662f\u5728\u8bb8\u4e09\u89c2\u7684\u5fc3\u91cc\u7ad6\u8d77\u4e86\u4e00\u9053\u9ad8\u5899\u3002</li> <li>\u7b2c\u4e09\u6b21\uff0c\u7ed9\u6797\u82ac\u82b3\u9001\u793c\u3002\u4e24\u4eba\u53d1\u751f\u5173\u7cfb\u540e\u7684\u56de\u793c\u3002\u7b97\u662f\u4f55\u5c0f\u52c7\u7684\u4e8b\u4ecd\u5728\u4ed6\u5fc3\u91cc\u53d1\u9175\u7684\u7ed3\u679c\u5427\u3002</li> <li>\u7b2c\u56db\u6b21\uff0c\u95f9\u9965\u8352\uff0c\u7ed9\u5bb6\u4eba\u6539\u5584\u751f\u6d3b\u3002\u5927\u751f\u4ea7\u7684\u751f\u6d3b\u8fc7\u53bb\u540e\uff0c\u9965\u8352\u5230\u6765\u3002\u4e0e\u4e00\u4e50\u4e4b\u95f4\u7684\u9ad8\u5899\u5f00\u59cb\u74e6\u89e3\uff08\u7239\u4f60\u662f\u8981\u5e26\u6211\u53bb\u5403\u9762\u6761\u5417\uff1f\uff09\u3002</li> <li>\u7b2c\u4e94\u6b21\uff0c\u7ed9\u4e00\u4e50\u3001\u4e8c\u4e50\u4e0b\u4e61\u6539\u5584\u751f\u6d3b\u3002</li> <li>\u7b2c\u516d\u6b21\uff0c\u8bf7\u4e8c\u4e50\u961f\u957f\u5403\u996d\u3002\u5f97\u77e5\u963f\u65b9\u8180\u80f1\u6da8\u7834\uff0c\u6839\u9f99\u8111\u6ea2\u8840\u53bb\u4e16\u3002</li> <li>\u7b2c\u4e03\u6b21\uff0c\u4e00\u4e50\u809d\u708e\u6cbb\u75c5\u7684\u5f00\u59cb\u3002\u6797\u6d66\u7ad9\u3002\u4ed6\u4eba\u7684\u6e29\u6696\u3002</li> <li>\u7b2c\u516b\u6b21\uff0c\u767e\u91cc\u7ad9\u3002\u4ed6\u4eba\u7684\u6e29\u6696\u3002</li> <li>\u7b2c\u4e5d\u6b21\uff0c\u677e\u6797\u7ad9\u3002\u9669\u4e9b\u4f11\u514b\u3002</li> <li>\u7b2c\u5341\u6b21\uff0c\u9ec4\u5e97\u7ad9\u3002\u7ed3\u8bc6\u6765\u559c\u548c\u6765\u987a\u3002</li> <li>\u7b2c\u5341\u4e00\u6b21\uff0c\u4e03\u91cc\u5821\u7ad9\u3002</li> <li>\u7b2c\u5341\u4e8c\u6b21\uff0c\u957f\u5b81\u7ad9\u3002</li> <li>\u7b2c\u5341\u4e09\u6b21\uff0c\u60f3\u5403\u7092\u732a\u809d\u4e86\u3002\u4f46\u8840\u7ad9\u4e0d\u6536\u3002</li> </ul> <p>\u6ca1\u6709\u4ed4\u7ec6\u6570\u4e4b\u524d\uff0c\u611f\u89c9\u597d\u50cf\u8fd8\u6ca1\u6709\u8fd9\u4e48\u591a......\u5341\u4e09\u6b21\u554a\u539f\u6765\u3002</p> <p>\u770b\u5230\u6700\u540e\uff0c\u7ec8\u4e8e\u770b\u5230\u4e86\u4f59\u534e\u7684\u6c14\u606f\u3002\u548c\u6d3b\u7740\u4e00\u6837\uff0c\u4e0d\u559c\u4e0d\u5fe7\u3002\u798f\u8d35\u4e5f\u53ea\u662f\u4e00\u4e2a\u4eba\u548c\u4e00\u5934\u725b\u5728\u7530\u57c2\u4e0a\u8015\u79cd\u7740\uff0c\u8bb8\u4e09\u89c2\u4e5f\u53ea\u662f\u548c\u8bb8\u7389\u5170\u5728\u996d\u5e97\u91cc\u5403\u7740\u7092\u732a\u809d\uff0c\u5bbd\u6170\u7740\u3002\u5e73\u9759\u7684\u7ed3\u5c40\uff0c\u4e0d\u5e73\u9759\u7684\u4e00\u751f\u3002 \u4f46\u4ed6\u4eec\u4e5f\u53ea\u662f\u90a3\u4e2a\u65f6\u4ee3\u5343\u5343\u4e07\u4e07\u4e2a\u76f8\u4f3c\u7684\u4eba\u751f\u7684\u7f29\u5f71\u5427\u3002\u5e74\u5c11\u901d\u7236\u3001\u9965\u8352\u3001\u6279\u6597\u3001\u751f\u8001\u75c5\u6b7b......\u4ed6\u4eec\u7684\u4eba\u751f\u4e5f\u5e76\u6ca1\u6709\u4ec0\u4e48\u72ec\u7279\u7684\u7ecf\u5386\uff0c\u5e73\u51e1\u7684\u6545\u4e8b\u5792\u53e0\u51fa\u4e86\u4e0d\u5e73\u51e1\u3002\u6bcf\u4e00\u79cd\u4eba\u751f\u90fd\u6709\u5b83\u7684\u767e\u822c\u7684\u6ecb\u5473\u3002 \u6211\u4eec\u90fd\u5728\u7528\u5c0f\u5c0f\u7684\u4e16\u754c\u89c2\uff0c\u5c0f\u5c0f\u7684\u611f\u5b98\u53bb\u611f\u53d7\u3002\u5e73\u51e1\u5c31\u662f\u6700\u5927\u7684\u4e0d\u5e73\u51e1\u3002</p> <p>\u8fd9\u672c\u4e66\u4e2d\u4e5f\u53ef\u4ee5\u770b\u5230\u8bb8\u591a\u7acb\u4f53\u7684\u4eba\u7269</p> <ul> <li>\u8bb8\u4e09\u89c2\uff1a\u4ece\u4f17\uff08\u5a36\u4e86\u6cb9\u6761\u897f\u65bd\uff09\uff0c\u597d\u9762\u5b50\uff08\u5bf9\u4f55\u5c0f\u52c7\u8fd9\u4ef6\u4e8b\u5f88\u751f\u6c14\uff0c\u51fa\u8f68\uff0c\u5bf9\u4e00\u4e50\u7684\u4e8b\u4e0d\u7ba1\u4e0d\u987e\uff0c\u8ba8\u538c\u8bb8\u7389\u5170\u7684\u5927\u558a\u5927\u53eb\uff0c\u4f55\u5c0f\u52c7\u8f66\u7978\u540e\u4e32\u95e8\u5ba3\u626c\uff09\uff0c\u5584\u826f\uff08\u8ba9\u4e00\u4e50\u53bb\u7ed9\u4f55\u5c0f\u52c7\u62db\u9b42\uff09\uff0c\u7231\uff08\u5728\u8bb8\u7389\u5170\u88ab\u6279\u6597\u65f6\uff0c\u5b88\u62a4\u5979\uff1b\u5728\u4e00\u5bb6\u53d7\u82e6\u65f6\uff0c\u60f3\u6539\u5584\u751f\u6d3b\uff1b\u5c06\u4e00\u4e50\u4ece\u5c4b\u9876\u4e0a\u63a5\u4e0b\uff0c\u5e76\u4e3a\u5176\u6491\u8170\uff1b\u5728\u4e00\u4e50\u3001\u4e8c\u4e50\u53d7\u82e6\u65f6\uff0c\u66ff\u4ed6\u4eec\u7740\u60f3\uff1b\u5728\u4e00\u4e50\u751f\u75c5\u65f6\uff0c\u4e0d\u8981\u547d\u4e86\u5730\u5356\u8840\uff09......</li> <li>\u8bb8\u7389\u5170\uff1a\u6211\u89c9\u5f97\u662f\u4e2a\u5f88\u6b63\u9762\u7684\u89d2\u8272\u3002\u8981\u9762\u5b50\uff08\u6bcf\u5468\u4e0d\u91cd\u6837\u7684\u6362\u8863\u670d\uff0c\u4f55\u5c0f\u52c7\u7684\u5973\u4eba\u6765\u8bc9\u82e6\u65f6\u53cd\u5411\u70ab\u8000\uff09\uff0c\u5c45\u5b89\u601d\u5371\uff08\u5b58\u7c73\uff09\uff0c\u76f4\u7387\uff0c\u7231\uff08\u7231\u4e00\u4e50\uff0c\u7231\u8bb8\u4e09\u89c2\uff0c\u7231\u8fd9\u4e2a\u5bb6\uff09\uff0c\u4e0d\u843d\u4e95\u4e0b\u77f3\uff0c\u5584\u826f......</li> <li>\u4f55\u5c0f\u52c7\u7684\u5973\u4eba\uff0c\u674e\u8840\u5934\uff0c\u4e00\u4e50\uff0c\u4e8c\u4e50\uff0c\u4e09\u4e50......</li> </ul> <p>\u90a3\u6837\u7684\u65f6\u4ee3\uff0c\u6709\u4eba\u6c11\u516c\u793e\uff0c\u5927\u8fd0\u52a8\uff0c\u9965\u8352\uff0c\u6587\u9769\uff0c\u592a\u591a\u592a\u591a\u7684\u5236\u5ea6\u9ed1\u6697\u4e0e\u65e0\u529b\u3002\u540c\u6837\u4e5f\u6709\u90a3\u4e48\u591a\u7684\u4f1f\u5927\u4e0e\u4e0d\u5c48\u3002\u4ed6\u4eec\u6ca1\u6709\u5411\u547d\u8fd0\u5c48\u670d\uff0c\u53ea\u662f\u5e73\u9759\u5730\u63a5\u53d7\uff0c\u7ee7\u7eed\u7740\u4ed6\u4eec\u7684\u4eba\u751f\u3002\u6211\u770b\u5230\u4e86\u7238\u7238\u7684\u5f71\u5b50\uff0c\u5f88\u50cf\u5427\uff1f\u91cc\u9762\u6709\u53e5\u8bdd\u6211\u5f88\u52a8\u5bb9\uff0c\u8bb8\u4e09\u89c2\u8bf4\uff0c\u6211\u5df2\u7ecf\u4f53\u9a8c\u4e86\u5f88\u591a\uff0c\u4f46\u662f\u6211\u513f\u5b50\u7684\u4eba\u751f\u624d\u521a\u521a\u5f00\u59cb\uff0c\u6240\u4ee5\u5c31\u7b97\u6211\u6ca1\u547d\u4e86\uff0c\u8fd9\u8f88\u5b50\u4e5f\u503c\u4e86\u3002\u8fd9\u6837\u4e3a\u4e86\u5b50\u5973\u800c\u53ef\u4ee5\u4e0d\u987e\u4e00\u5207\u7684\u4e00\u4ee3\u4eba\uff0c\u8fd8\u4f1a\u5728\u8fd9\u4e2a\u4e16\u754c\u505c\u7559\u591a\u4e45\u5462\uff1f\u6211\u4eec\u53c8\u4fdd\u7559\u4e86\u591a\u5c11\u5462\uff1f\u6211\u4eec\u73b0\u5728\u5f88\u591a\u4eba\u90fd\u5728\u62b1\u6028\uff0c\u62b1\u6028\u4ed6\u4eec\u4e0d\u662f\u4e00\u4ee3\u5408\u683c\u7684\u7236\u6bcd\u3002\u53ef\u662f\u4ed6\u4eec\u4e5f\u4e0d\u77e5\u7231\u662f\u4ec0\u4e48\uff0c\u4e5f\u6ca1\u6709\u4f53\u9a8c\u8fc7\u6211\u4eec\u60f3\u8981\u7684\u7231\u3002\u53c8\u6216\u8bb8\u6211\u4eec\u4e5f\u4e0d\u6e05\u695a\u4ec0\u4e48\u662f\u7231\u4ee5\u53ca\u5982\u4f55\u53bb\u7231\uff0c\u4e0d\u662f\u5417\uff1f\u5b50\u5973\u548c\u7236\u6bcd\u672c\u5c31\u662f\u4e00\u4e2a\u76f8\u4e92\u6210\u957f\u7684\u5173\u7cfb\u5427\u3002\u6211\u4eec\u90fd\u5728\u6162\u6162\u5b66\u7740\u611f\u53d7\u7231\uff0c\u53bb\u7231\u3002\u6216\u8bb8\u4ed6\u4eec\u4e5f\u5df2\u7aed\u5c3d\u5168\u529b\uff0c\u7ed9\u4e86\u4ed6\u4eec\u8ba4\u4e3a\u6240\u80fd\u7ed9\u6211\u4eec\u7684\u4e00\u5207\u3002\u6211\u4eec\u4e5f\u4e0d\u5e94\u8be5\u5f3a\u6c42\u4efb\u4f55\u4eba\u505a\u5230\u6211\u4eec\u90fd\u4e0d\u4f1a\u7684\u4e8b\u3002</p> <p>\u8bb0\u5f55\u51e0\u53e5\u5927\u5bb6\u7684\u8bc4\u8bba\u548c\u4e66\u4e2d\u7684\u8bdd\uff1a - \u8fd9\u4e2a\u4e16\u754c\uff0c\u94b1\u90fd\u6d41\u5411\u4e86\u4e0d\u7f3a\u94b1\u7684\u4eba\uff0c\u7231\u4e5f\u90fd\u6d41\u5411\u4e86\u4e0d\u7f3a\u7231\u7684\u4eba\uff0c\u82e6\u4e5f\u90fd\u7559\u7ed9\u4e86\u90a3\u4e9b\u80fd\u5403\u82e6\u7684\u4eba\u3002 - \u4ed6\u7684\u811a\u5728\u5f80\u524d\u8d70\uff0c\u4ed6\u7684\u773c\u6cea\u5728\u5f80\u4e0b\u6d41\u3002</p>"}]}